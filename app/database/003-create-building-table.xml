<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="003" author="developer">
        <comment>Создание таблицы BUILDING (Корпуса)</comment>
        <createTable schemaName="map_app" tableName="building">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(500)">
                <constraints nullable="false"/>
            </column>
            <column name="short_name" type="varchar(100)"/>
        </createTable>

        <addDefaultValue schemaName="map_app" tableName="building" columnName="id" defaultValueComputed="uuid_generate_v4()"/>

        <rollback>
            <dropTable schemaName="map_app" tableName="building"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
