<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="005" author="developer">
        <comment>Создание таблицы ROOM (Аудитории)</comment>
        <createTable schemaName="map_app" tableName="room">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="building_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="floor_number" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="number" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(500)"/>
            <column name="room_type" type="varchar(200)"/>
            <column name="coordinates" type="jsonb"/>
        </createTable>

        <addDefaultValue schemaName="map_app" tableName="room" columnName="id" defaultValueComputed="uuid_generate_v4()"/>

        <sql>
            ALTER TABLE map_app.room
            ADD CONSTRAINT fk_room_building
            FOREIGN KEY (building_id)
            REFERENCES map_app.building(id);
        </sql>

        <rollback>
            <dropTable schemaName="map_app" tableName="room"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
