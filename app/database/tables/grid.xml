<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="grid" author="developer">
        <comment>Создание таблицы GRID (Сетка навигации)</comment>
        <createTable schemaName="map_app" tableName="grid">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="building_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="floor_number" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="cell_size" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="nodes" type="jsonb"/>
            <column name="edges" type="jsonb"/>
            <column name="entrance_connections" type="jsonb"/>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addDefaultValue schemaName="map_app" tableName="grid" columnName="id" defaultValueComputed="uuid_generate_v4()"/>

        <addUniqueConstraint schemaName="map_app" tableName="grid" columnNames="building_id, floor_number" constraintName="uq_grid_building_floor"/>

        <sql>
            ALTER TABLE map_app.grid
            ADD CONSTRAINT fk_grid_building
            FOREIGN KEY (building_id)
            REFERENCES map_app.building(id);
        </sql>

        <rollback>
            <dropTable schemaName="map_app" tableName="grid"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
