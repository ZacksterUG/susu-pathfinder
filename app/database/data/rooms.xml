<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="rooms" author="developer" runOnChange="true">
        <comment>Перенос данных из rooms.json в таблицу room</comment>
        <sql>DELETE FROM map_app.room;</sql>
        <sqlFile path="rooms.sql" relativeToChangelogFile="true" splitStatements="true"/>
        <rollback>
            <sql>DELETE FROM map_app.room;</sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
